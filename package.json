{
  "name": "fandom-gui-scraper",
  "version": "1.0.0",
  "description": "Universal Fandom Wiki Scraper with GUI - Frontend Testing",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/frontend/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/frontend/integration",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/frontend/e2e",
    "lint": "eslint frontend/js/**/*.js",
    "lint:fix": "eslint frontend/js/**/*.js --fix",
    "demo:dev": "npm --prefix demo-app run dev",
    "demo:build": "npm --prefix demo-app run build",
    "demo:preview": "npm --prefix demo-app run preview",
    "dev": "npm --prefix demo-app run dev",
    "build": "npm --prefix demo-app run build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3"
  },
  "keywords": [
    "fandom",
    "scraper",
    "anime",
    "wiki",
    "testing",
    "jest"
  ],
  "author": "Your Name",
  "license": "MIT"
}
